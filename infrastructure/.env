SERVER_PORT=8081
SPRING_APPLICATION_NAME=expense-service
DB_HOST=postgres
DB_PORT=5432
DB_NAME=spendsmart_expense
DB_USERNAME=postgres
DB_PASSWORD=postgres
SPRING_JPA_OPEN_IN_VIEW=false
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=classpath:db/migration
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
JWT_SECRET=myverylonglocalsecretsigninkeyforjwt12345678
JWT_EXPIRATION=86400000

# AWS Configuration - Replace with your AWS credentials and resources
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# AWS SQS Queue URLs
AWS_SQS_QUEUE_URL=arn:aws:sqs:ap-south-1:YOUR_ACCOUNT_ID:expense-events
AWS_SQS_QUEUE_CATEGORIZATION=arn:aws:sqs:ap-south-1:YOUR_ACCOUNT_ID:expense-created.fifo
AWS_SQS_QUEUE_OCR=arn:aws:sqs:ap-south-1:YOUR_ACCOUNT_ID:ocr-queue
AWS_SQS_QUEUE_UPI=arn:aws:sqs:ap-south-1:YOUR_ACCOUNT_ID:upi-events
AWS_SQS_QUEUE_NOTIFICATIONS=arn:aws:sqs:ap-south-1:YOUR_ACCOUNT_ID:notifications
AWS_SQS_QUEUE_EXPENSE_SUBMITTED=arn:aws:sqs:ap-south-1:YOUR_ACCOUNT_ID:expense-submitted
AWS_SQS_QUEUE_EXPENSE_EVENTS=arn:aws:sqs:ap-south-1:YOUR_ACCOUNT_ID:expense-events

# AWS SNS Topics
AWS_SNS_EXPENSE_EVENTS_TOPIC_ARN=arn:aws:sns:ap-south-1:YOUR_ACCOUNT_ID:expense-events
AWS_SNS_RECEIPT_EVENTS_TOPIC_ARN=arn:aws:sns:ap-south-1:YOUR_ACCOUNT_ID:receipt-events
AWS_SNS_ANOMALY_ALERT_TOPIC_ARN=arn:aws:sns:ap-south-1:YOUR_ACCOUNT_ID:anomaly-alerts

# AWS S3 Bucket
AWS_S3_BUCKET_NAME=spendsmart-receipts

MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
